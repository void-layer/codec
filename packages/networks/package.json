{
  "name": "@void-layer/networks",
  "version": "0.1.0",
  "description": "Chain configs, token list, block explorer helpers, and wagmi chain configs for @void-layer ecosystem. NO RPC keys.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./get-chain": { "import": "./dist/get-chain.js", "types": "./dist/get-chain.d.ts" },
    "./explorer": { "import": "./dist/explorer.js", "types": "./dist/explorer.d.ts" },
    "./tokens": { "import": "./dist/tokens.js", "types": "./dist/tokens.d.ts" },
    "./wagmi": { "import": "./dist/wagmi.js", "types": "./dist/wagmi.d.ts" }
  },
  "files": ["dist/", "README.md", "LICENSE", "CHANGELOG.md"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/void-layer/codec.git",
    "directory": "packages/networks"
  },
  "license": "MIT",
  "author": "void-layer",
  "homepage": "https://github.com/void-layer/codec/tree/main/packages/networks#readme",
  "bugs": { "url": "https://github.com/void-layer/codec/issues" },
  "keywords": ["voidpay","void-layer","ethereum","chains","tokens","web3"],
  "sideEffects": false,
  "publishConfig": { "access": "public", "provenance": true },
  "dependencies": {
    "@void-layer/types": "workspace:^"
  },
  "peerDependencies": {
    "viem": ">=2.0.0 <3.0.0"
  },
  "peerDependenciesMeta": {
    "viem": { "optional": true }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.10",
    "viem": "^2.55.2",
    "vitest": "^4.1.10"
  },
  "engines": { "node": ">=18" }
}
